---

<section class="contact">
  <div class="contact-inner">

    <!-- Left: intro text -->
    <div class="contact-intro">
      <div class="contact-eyebrow eyebrow" data-i18n="contactEyebrow">Enquiries</div>
      <h2 class="contact-heading" data-i18n="contactHeading">Arrange a visit</h2>
      <p class="contact-body" data-i18n="contactBody">
        Tell us a little about yourself and we'll be in touch to plan a private viewing of the estate.
      </p>
    </div>

    <!-- Right: form / success -->
    <div class="contact-form-wrap">

      <!-- Success state (hidden by default) -->
      <div class="contact-success" id="contactSuccess" hidden>
        <div class="success-heading" data-i18n="sentTitle">Thank you</div>
        <p class="success-body" data-i18n="sentBody">
          We've received your message and will reply shortly.
        </p>
      </div>

      <!-- Form -->
      <form class="contact-form" id="contactForm" novalidate>

        <label class="field">
          <span class="field-label" data-i18n="fName">Name</span>
          <input type="text" name="name" required autocomplete="name" />
        </label>

        <label class="field">
          <span class="field-label" data-i18n="fEmail">Email</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>

        <label class="field">
          <span class="field-label" data-i18n="fMsg">Message</span>
          <textarea name="message" rows="3"></textarea>
        </label>

        <button type="submit" class="submit-btn" data-i18n="fSend">Send enquiry</button>

      </form>
    </div>

  </div>
</section>

<style>
.contact {
  background: var(--ink);
  color: var(--paper);
  padding: clamp(80px, 12vh, 140px) clamp(24px, 5vw, 48px);
}

.contact-inner {
  max-width: 1080px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: clamp(40px, 6vw, 90px);
  align-items: start;
}

/* ── Left column ── */
.contact-eyebrow {
  margin-bottom: 26px;
}

.contact-heading {
  font-weight: 400;
  font-size: clamp(36px, 5vw, 64px);
  line-height: 1.04;
  margin: 0 0 26px;
  letter-spacing: -0.01em;
}

.contact-body {
  font-size: clamp(18px, 2vw, 22px);
  line-height: 1.6;
  color: rgba(244, 239, 230, 0.7);
  max-width: 420px;
}

/* ── Form ── */
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 30px;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.field-label {
  font-family: var(--label);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(244, 239, 230, 0.55);
}

.field input,
.field textarea {
  background: none;
  border: none;
  border-bottom: 1px solid rgba(244, 239, 230, 0.3);
  color: var(--paper);
  font-size: 20px;
  padding: 6px 0;
  outline: none;
  font-family: var(--serif);
  resize: none;
  transition: border-color 0.15s;
  -webkit-appearance: none;
}

.field input:focus,
.field textarea:focus {
  border-bottom-color: var(--accent);
}

/* Submit button */
.submit-btn {
  align-self: flex-start;
  margin-top: 8px;
  background: var(--accent);
  color: var(--paper);
  border: none;
  padding: 16px 34px;
  font-family: var(--label);
  font-size: 12px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity 0.15s;
}

.submit-btn:hover {
  opacity: 0.88;
}

/* ── Success state ── */
.contact-success {
  border-top: 1px solid rgba(244, 239, 230, 0.25);
  padding-top: 40px;
}

.success-heading {
  font-family: var(--serif);
  font-size: clamp(28px, 4vw, 40px);
  margin-bottom: 12px;
  font-weight: 400;
}

.success-body {
  font-family: var(--label);
  font-size: 13px;
  line-height: 1.7;
  color: rgba(244, 239, 230, 0.65);
}
</style>
