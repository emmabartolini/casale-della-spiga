---
---

<section class="hero">
  <!-- Placeholder stripes — visible until video loads -->
  <div class="hero-bg" aria-hidden="true"></div>

    <video
      id="heroVideo"
      class="hero-video"
      src="/casale-della-spiga/video/hero.mp4"
      autoplay
      muted
      loop
      playsinline
      poster="/casale-della-spiga/video/hero-poster.jpg"
    ></video>

  <!-- Gradient overlay -->
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Mute / unmute button (bottom-right) -->
  <button class="mute-btn" id="muteBtn" aria-label="Unmute video" aria-pressed="true">
    <svg class="icon-muted" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <!-- Speaker with X -->
      <path d="M11 5 6 9H3a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h3l5 4V5Z"/>
      <line x1="23" y1="9" x2="17" y2="15"/>
      <line x1="17" y1="9" x2="23" y2="15"/>
    </svg>
    <svg class="icon-unmuted" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <!-- Speaker with waves -->
      <path d="M11 5 6 9H3a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h3l5 4V5Z"/>
      <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
      <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
    </svg>
  </button>

  <!-- Copy -->
  <div class="hero-copy">
    <p class="hero-eyebrow" data-i18n="heroEyebrow">Emilia Romagna — Italy</p>
    <p class="hero-sub" data-i18n="heroSub">A historic brick and stone farmhouse in the green heart of Italy</p>
  </div>
</section>

<script>
  const video   = document.getElementById('heroVideo')   as HTMLVideoElement | null;
  const muteBtn = document.getElementById('muteBtn')     as HTMLButtonElement | null;

  if (video && muteBtn) {
    muteBtn.addEventListener('click', () => {
      video.muted = !video.muted;
      const isMuted = video.muted;
      muteBtn.setAttribute('aria-pressed', String(isMuted));
      muteBtn.setAttribute('aria-label', isMuted ? 'Unmute video' : 'Mute video');
      muteBtn.classList.toggle('is-muted', isMuted);
    });
  }
</script>

<style>
.hero {
  position: relative;
  height: 100vh;
  min-height: 640px;
  width: 100%;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    135deg,
    #3a3128 0, #3a3128 13px,
    #423930 13px, #423930 26px
  );
}

/* ── Video ── */
.hero-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(22, 17, 12, 0.78) 0%,
    rgba(22, 17, 12, 0.30) 45%,
    rgba(22, 17, 12, 0.42) 100%
  );
}

/* ── Mute button ── */
.mute-btn {
  position: absolute;
  bottom: clamp(36px, 6vh, 72px);
  right: clamp(20px, 4vw, 48px);
  z-index: 6;
  background: none;
  border: 1px solid rgba(244, 239, 230, 0.35);
  color: rgba(244, 239, 230, 0.8);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  backdrop-filter: blur(2px);
  transition: border-color 0.2s, color 0.2s;
}

.mute-btn:hover {
  border-color: rgba(244, 239, 230, 0.75);
  color: rgba(244, 239, 230, 1);
}

/* default state = muted → show the X-speaker icon */
.mute-btn .icon-muted  { display: block; }
.mute-btn .icon-unmuted { display: none; }

/* when video is playing with sound → show the waves icon */
.mute-btn:not(.is-muted) .icon-muted   { display: none; }
.mute-btn:not(.is-muted) .icon-unmuted { display: block; }

/* ── Hero copy ── */
.hero-copy {
  position: absolute;
  left: clamp(20px, 4vw, 48px);
  bottom: clamp(36px, 6vh, 72px);
  right: calc(clamp(20px, 4vw, 48px) + 56px); /* leaves space for mute btn */
  color: var(--paper);
  z-index: 6;
}

.hero-eyebrow {
  font-family: var(--label);
  font-size: 12px;
  letter-spacing: 0.26em;
  text-transform: uppercase;
  color: rgba(244, 239, 230, 0.85);
  margin-bottom: 20px;
}

.hero-sub {
  font-size: clamp(20px, 2.4vw, 30px);
  line-height: 1.3;
  max-width: 620px;
  color: rgba(244, 239, 230, 0.92);
  font-weight: 300;
}
</style>
