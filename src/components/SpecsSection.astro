---
interface Props {
  priceVisible?: boolean;
}
const { priceVisible = true } = Astro.props;
---

<section class="specs">
  <div class="specs-eyebrow eyebrow" data-i18n="specsEyebrow">Information</div>

  <div class="specs-grid">

    <!-- Rooms -->
    <div class="spec-cell">
      <span class="spec-icon" aria-hidden="true">
        <svg width="34" height="34" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 17V11a3 3 0 0 1 3-3h14a3 3 0 0 1 3 3v6 M9.5 17v-2.5a1.5 1.5 0 0 1 1.5-1.5h2.5a1.5 1.5 0 0 1 1.5 1.5V17 M17 17v-2.5a1.5 1.5 0 0 1 1.5-1.5H21a1.5 1.5 0 0 1 1.5 1.5V17 M4 23.5V19a2 2 0 0 1 2-2h20a2 2 0 0 1 2 2v4.5 M10 21.5h12 M5 23.5V26M27 23.5V26"/>
        </svg>
      </span>
      <div class="spec-number">11</div>
      <div class="spec-label" data-i18n="specRooms">Rooms</div>
    </div>

    <!-- Bathrooms -->
    <div class="spec-cell">
      <span class="spec-icon" aria-hidden="true">
        <svg width="34" height="34" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 18.5h22 M7 18.5l1.5 7.5h15l1.5-7.5 M10 26v1.8M22 26v1.8 M11.5 18.5V10a1.6 1.6 0 0 1 1.6-1.6 M13.1 8.4q2.6-1 4.7 1.4 M13.6 12.4l.7 1.2M16.1 11.9l.7 1.2M14.7 15.1l.7 1.2M17.2 14.6l.7 1.2"/>
        </svg>
      </span>
      <div class="spec-number">3</div>
      <div class="spec-label" data-i18n="specBaths">Bathrooms</div>
    </div>

    <!-- Square meters -->
    <div class="spec-cell">
      <span class="spec-icon" aria-hidden="true">
        <svg width="34" height="34" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 4h12l6 6v18H8z M20 4v6h6 M12 13h11v11H12z M17 13v5M12 18h5 M17 18a5 5 0 0 1 5 5"/>
        </svg>
      </span>
      <div class="spec-number">420</div>
      <div class="spec-label" data-i18n="specArea">Square meters</div>
    </div>

    <!-- Units -->
    <div class="spec-cell">
      <span class="spec-icon" aria-hidden="true">
        <svg width="34" height="34" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 14.5V27h20V14.5 M3.5 15l3-7h19l3 7z M13 6.5h2.2v2.5 M11 18.5h2.5v2.5H11z M18.5 18.5H21v2.5h-2.5z M11 23.5h2.5v2.5H11z M18.5 23.5H21v2.5h-2.5z"/>
        </svg>
      </span>
      <div class="spec-number">2</div>
      <div class="spec-label" data-i18n="specUnits">Units</div>
    </div>

    <!-- Price -->
    {priceVisible && (
      <div class="spec-cell">
        <span class="spec-icon" aria-hidden="true">
          <svg width="34" height="34" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4.5 9h23a1.5 1.5 0 0 1 1.5 1.5v11a1.5 1.5 0 0 1-1.5 1.5h-23a1.5 1.5 0 0 1-1.5-1.5v-11a1.5 1.5 0 0 1 1.5-1.5z M16 12.7a3.3 3.3 0 1 0 0 6.6a3.3 3.3 0 1 0 0-6.6z M7 9.5a2.5 2.5 0 0 1-2.5 2.5 M25 9.5a2.5 2.5 0 0 0 2.5 2.5 M7 22.5a2.5 2.5 0 0 0-2.5-2.5 M25 22.5a2.5 2.5 0 0 1 2.5-2.5"/>
          </svg>
        </span>
        <div class="spec-number">€1M</div>
        <div class="spec-label" data-i18n="specPrice">Price</div>
      </div>
    )}

  </div>
</section>

<style>
.specs {
  background: var(--sand);
  border-top: 1px solid rgba(43, 38, 32, 0.12);
  border-bottom: 1px solid rgba(43, 38, 32, 0.12);
  padding: clamp(56px, 8vh, 90px) clamp(24px, 5vw, 48px);
}

.specs-eyebrow {
  text-align: center;
  margin-bottom: 56px;
}

.specs-grid {
  max-width: 1080px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 48px 24px;
}

.spec-cell {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}

.spec-icon {
  color: var(--accent);
}

.spec-number {
  font-size: clamp(46px, 5vw, 68px);
  line-height: 1;
  font-weight: 400;
  font-family: var(--serif);
}

.spec-label {
  font-family: var(--label);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--muted);
}
</style>
